{
  "name": "rush-fitness-gms",
  "version": "1.0.0",
  "description": "Rush Fitness Centre Gym Management System",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "lucide-react": "^0.263.1"
  },
  "scripts": {
    "start": "PORT=3003 react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "backend:install": "cd backend && npm install",
    "backend:dev": "cd backend && npm run dev",
    "backend:migrate": "cd backend && npm run db:create && npm run db:migrate && npm run db:seed",
    "dev": "concurrently -k -n web,api -c blue,green \"npm start\" \"npm --prefix backend run dev\""
  },
  "proxy": "http://localhost:4000",
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
