# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3003

# ── Database ─────────────────────────────────────────────
# On a fresh Postgres install via Homebrew the username is your macOS user
# and the password is empty. Adjust if you used a different setup.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rush_fitness_gms
DB_USER=postgres
DB_PASSWORD=
# Or use a single connection string instead of the parts above:
# DATABASE_URL=postgres://postgres:@localhost:5432/rush_fitness_gms

# ── Auth ─────────────────────────────────────────────────
# IMPORTANT: change this to a long random string in production.
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=10

# ── Locale / business defaults ───────────────────────────
CURRENCY=KES
LOCALE=en-KE

# ── Initial admin (created by seed) ──────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=System Administrator
